# =============================================
# SAFIRA - Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# =============================================

# Database MySQL (Hostinger)
# Format: mysql://username:password@localhost:3306/nama_database
# connection_limit & socket_timeout penting agar konten besar (gambar base64) bisa tersimpan
DATABASE_URL="mysql://username:password@localhost:3306/safira_db?connection_limit=10&socket_timeout=60"

# JWT
JWT_SECRET="ganti-dengan-string-acak-yang-panjang-dan-aman"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=production

# URL Frontend — WAJIB diisi dengan URL production, digunakan untuk QR Code verifikasi surat
# Jangan gunakan localhost di production!
FRONTEND_URL="https://sirama.masyppsukamiskin.sch.id"

# Upload directory (relatif dari root backend)
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=10485760

# VAPID Keys untuk Web Push Notification
# Generate dengan: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:admin@masyppsukamiskin.sch.id"

# Secret untuk endpoint setup/seed (hapus setelah seed selesai)
SETUP_SECRET="your-setup-secret"
