# =============================================
# SAFIRA Backend - Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# =============================================

# Database (PostgreSQL - wajib diisi)
DATABASE_URL="postgresql://username:password@host:5432/safira_db"

# JWT
JWT_SECRET="ganti-dengan-string-acak-yang-panjang-dan-aman"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=production

# Frontend URL (ganti dengan domain frontend Anda)
FRONTEND_URL="https://yourdomain.com"

# Upload directory (relatif dari root backend)
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=10485760

# VAPID Keys untuk Web Push Notification
# Generate dengan: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:admin@yourdomain.com"
