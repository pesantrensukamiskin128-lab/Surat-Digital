generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TATA_USAHA
  KEPALA
  GURU
}

enum SuratStatus {
  DRAFT
  MENUNGGU_TATA_USAHA
  MENUNGGU_KEPALA
  DITOLAK_TATA_USAHA
  DITOLAK_KEPALA
  SELESAI
}

enum SuratMasukStatus {
  BARU
  DIBACA
  DIDISPOSISI
}

enum JenisSurat {
  A
  B
  C
  D
  E
  F
  G
  H
  I
  J
  K
  SK
}

enum KategoriAgenda {
  MUSYAWARAH
  RAPAT
  PENGAJIAN
  LAIN_LAIN
}

enum TipeAgenda {
  LURING
  DARING
  HIBRID
}

enum ZonaWaktu {
  WIB
  WITA
  WIT
}

enum MetodeKehadiran {
  APLIKASI
  FORM
}

model OrganisasiProfil {
  id              String   @id @default(uuid()) @db.VarChar(36)
  tingkatanOrg    String   @default("Pimpinan Cabang")
  namaOrg         String   @default("Fatayat Nahdlatul Ulama")
  daerahOrg       String   @default("Kota Bandung")
  alamat          String   @default("") @db.Text
  telepon         String   @default("")
  email           String   @default("")
  website         String   @default("")
  kodeKlasifikasi String   @default("PP.06")
  logoPath        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id            String    @id @default(uuid()) @db.VarChar(36)
  email         String    @unique
  password      String
  namaLengkap   String
  jabatan       String    @default("")
  nomorHp       String    @default("")
  role          Role      @default(GURU)
  isActive      Boolean   @default(true)
  fotoProfil    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  suratDibuat         SuratKeluar[]      @relation("SuratDibuat")
  suratTataUsaha      SuratKeluar[]      @relation("SuratTataUsaha")
  suratKepala         SuratKeluar[]      @relation("SuratKepala")
  penerimaInternal    PenerimaInternal[]
  disposisiDiterima   Disposisi[]        @relation("DisposisiPenerima")
  disposisiDibuat     Disposisi[]        @relation("DisposisiDibuat")
  suratMasukDiupload  SuratMasuk[]       @relation("SuratMasukUploader")
  pushSubscriptions   PushSubscription[]
  notifikasi          Notifikasi[]
  agendaDibuat        Agenda[]
  pesertaAgenda       PesertaAgenda[]
  kehadiran           Kehadiran[]
}

model SuratKeluar {
  id              String      @id @default(uuid()) @db.VarChar(36)
  nomorSurat      String?     @unique
  jenisSurat      JenisSurat  @default(A)
  perihal         String
  lampiran        String?
  isiSurat        String      @db.Text
  lampiranIsi     String?     @db.Text
  tujuanSurat     String?     @db.Text
  tanggalMasehi   DateTime
  tanggalHijriyah String
  tempatTerbit    String      @default("Bandung")
  status          SuratStatus @default(DRAFT)

  tataUsahaId     String?     @db.VarChar(36)
  kepalaId        String?     @db.VarChar(36)
  tataUsaha       User?       @relation("SuratTataUsaha", fields: [tataUsahaId], references: [id])
  kepala          User?       @relation("SuratKepala", fields: [kepalaId], references: [id])

  parafTataUsaha   Boolean     @default(false)
  ttdKepala        Boolean     @default(false)
  tglParafTataUsaha DateTime?
  tglTtdKepala     DateTime?

  catatanTolak    String?     @db.Text
  ditolakOleh     String?

  qrCodePath      String?
  qrCodeToken     String?     @unique

  pembuatId       String      @db.VarChar(36)
  pembuat         User        @relation("SuratDibuat", fields: [pembuatId], references: [id])

  penerimaEksternal String?   @db.Text
  penerimaInternal  PenerimaInternal[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model PenerimaInternal {
  id          String      @id @default(uuid()) @db.VarChar(36)
  suratId     String      @db.VarChar(36)
  userId      String      @db.VarChar(36)
  sudahDibaca Boolean     @default(false)
  dibacaAt    DateTime?
  surat       SuratKeluar @relation(fields: [suratId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])
  createdAt   DateTime    @default(now())
}

model SuratMasuk {
  id              String           @id @default(uuid()) @db.VarChar(36)
  nomorSurat      String?
  pengirim        String
  perihal         String
  isiSurat        String?          @db.Text
  lampiran        String?          @db.Text
  tanggalSurat    DateTime
  tanggalTerima   DateTime         @default(now())
  status          SuratMasukStatus @default(BARU)
  filePath        String?
  uploaderId      String           @db.VarChar(36)
  uploader        User             @relation("SuratMasukUploader", fields: [uploaderId], references: [id])
  disposisi       Disposisi[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique @db.VarChar(500)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(255)
  createdAt DateTime @default(now())
}

model Notifikasi {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  judul     String
  pesan     String   @db.Text
  url       String   @default("/")
  dibaca    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Agenda {
  id              String         @id @default(uuid()) @db.VarChar(36)
  namaAgenda      String
  penyelenggara   String
  kategori        KategoriAgenda @default(RAPAT)
  tipe            TipeAgenda     @default(LURING)
  tempat          String
  tanggal         DateTime
  waktuMulai      String
  waktuSelesai    String
  zonaWaktu       ZonaWaktu      @default(WIB)
  deskripsi       String?        @db.Text
  qrToken         String         @unique @default(uuid()) @db.VarChar(36)
  pembuatId       String         @db.VarChar(36)
  pembuat         User           @relation(fields: [pembuatId], references: [id])
  peserta         PesertaAgenda[]
  kehadiran       Kehadiran[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model PesertaAgenda {
  id        String  @id @default(uuid()) @db.VarChar(36)
  agendaId  String  @db.VarChar(36)
  userId    String  @db.VarChar(36)
  agenda    Agenda  @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([agendaId, userId])
}

model Kehadiran {
  id          String          @id @default(uuid()) @db.VarChar(36)
  agendaId    String          @db.VarChar(36)
  agenda      Agenda          @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  userId      String?         @db.VarChar(36)
  user        User?           @relation(fields: [userId], references: [id])
  namaLengkap String
  nomorHp     String?
  instansi    String?
  jabatan     String?
  metode      MetodeKehadiran @default(APLIKASI)
  waktuHadir  DateTime        @default(now())
  createdAt   DateTime        @default(now())
}

model Disposisi {
  id              String     @id @default(uuid()) @db.VarChar(36)
  suratMasukId    String     @db.VarChar(36)
  suratMasuk      SuratMasuk @relation(fields: [suratMasukId], references: [id], onDelete: Cascade)
  dibuatOlehId    String     @db.VarChar(36)
  dibuatOleh      User       @relation("DisposisiDibuat", fields: [dibuatOlehId], references: [id])
  penerimaId      String     @db.VarChar(36)
  penerima        User       @relation("DisposisiPenerima", fields: [penerimaId], references: [id])
  instruksi       String     @db.Text
  catatan         String?    @db.Text
  sudahDibaca     Boolean    @default(false)
  dibacaAt        DateTime?
  jawaban         String?    @db.Text
  dijawabAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}
