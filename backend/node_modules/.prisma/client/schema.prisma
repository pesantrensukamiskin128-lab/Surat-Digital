generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SEKRETARIS
  KETUA
  PENGURUS
}

enum SuratStatus {
  DRAFT
  MENUNGGU_SEKRETARIS
  MENUNGGU_KETUA
  DITOLAK_SEKRETARIS
  DITOLAK_KETUA
  SELESAI
}

enum SuratMasukStatus {
  BARU
  DIBACA
  DIDISPOSISI
}

// Jenis surat
enum JenisSurat {
  A
  B
  C
  D
  E
  F
  G
  H
  I
  J
  K
  SK
}

model OrganisasiProfil {
  id           String   @id @default(uuid())
  tingkatanOrg String   @default("Pimpinan Cabang")
  namaOrg      String   @default("Fatayat Nahdlatul Ulama")
  daerahOrg    String   @default("Kota Bandung")
  alamat       String   @default("")
  telepon      String   @default("")
  email        String   @default("")
  website      String   @default("")
  logoPath     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  namaLengkap String
  jabatan     String   @default("")
  nomorHp     String   @default("")
  role        Role     @default(PENGURUS)
  isActive    Boolean  @default(true)
  fotoProfil  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  suratDibuat        SuratKeluar[]      @relation("SuratDibuat")
  suratSekretaris    SuratKeluar[]      @relation("SuratSekretaris")
  suratKetua         SuratKeluar[]      @relation("SuratKetua")
  penerimaInternal   PenerimaInternal[]
  disposisiDiterima  Disposisi[]        @relation("DisposisiPenerima")
  disposisiDibuat    Disposisi[]        @relation("DisposisiDibuat")
  suratMasukDiupload SuratMasuk[]       @relation("SuratMasukUploader")
  pushSubscriptions  PushSubscription[]
  notifikasi         Notifikasi[]
  agendaDibuat       Agenda[]
  pesertaAgenda      PesertaAgenda[]
  kehadiran          Kehadiran[]
}

model SuratKeluar {
  id              String      @id @default(uuid())
  nomorSurat      String?     @unique
  jenisSurat      JenisSurat  @default(A)
  perihal         String
  lampiran        String?
  isiSurat        String      @db.Text
  lampiranIsi     String?     @db.Text
  tujuanSurat     String?     @db.Text
  tanggalMasehi   DateTime
  tanggalHijriyah String
  tempatTerbit    String      @default("Bandung")
  status          SuratStatus @default(DRAFT)

  sekretarisId String?
  ketuaId      String?
  sekretaris   User?   @relation("SuratSekretaris", fields: [sekretarisId], references: [id])
  ketua        User?   @relation("SuratKetua", fields: [ketuaId], references: [id])

  ttdSekretaris    Boolean   @default(false)
  ttdKetua         Boolean   @default(false)
  tglTtdSekretaris DateTime?
  tglTtdKetua      DateTime?

  catatanTolak String? @db.Text
  ditolakOleh  String?

  qrCodePath  String?
  qrCodeToken String? @unique

  pembuatId String
  pembuat   User   @relation("SuratDibuat", fields: [pembuatId], references: [id])

  penerimaEksternal String?
  penerimaInternal  PenerimaInternal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PenerimaInternal {
  id          String      @id @default(uuid())
  suratId     String
  userId      String
  sudahDibaca Boolean     @default(false)
  dibacaAt    DateTime?
  surat       SuratKeluar @relation(fields: [suratId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])
  createdAt   DateTime    @default(now())
}

model SuratMasuk {
  id            String           @id @default(uuid())
  nomorSurat    String?
  pengirim      String
  perihal       String
  isiSurat      String?          @db.Text
  lampiran      String?          @db.Text
  tanggalSurat  DateTime
  tanggalTerima DateTime         @default(now())
  status        SuratMasukStatus @default(BARU)
  filePath      String?
  uploaderId    String
  uploader      User             @relation("SuratMasukUploader", fields: [uploaderId], references: [id])
  disposisi     Disposisi[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Notifikasi {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  judul     String
  pesan     String
  url       String   @default("/")
  dibaca    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum KategoriAgenda {
  MUSYAWARAH
  RAPAT
  PENGAJIAN
  LAIN_LAIN
}

enum TipeAgenda {
  LURING
  DARING
  HIBRID
}

enum ZonaWaktu {
  WIB
  WITA
  WIT
}

model Agenda {
  id            String          @id @default(uuid())
  namaAgenda    String
  penyelenggara String
  kategori      KategoriAgenda  @default(RAPAT)
  tipe          TipeAgenda      @default(LURING)
  tempat        String
  tanggal       DateTime
  waktuMulai    String
  waktuSelesai  String
  zonaWaktu     ZonaWaktu       @default(WIB)
  deskripsi     String?         @db.Text
  qrToken       String          @unique @default(uuid())
  pembuatId     String
  pembuat       User            @relation(fields: [pembuatId], references: [id])
  peserta       PesertaAgenda[]
  kehadiran     Kehadiran[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model PesertaAgenda {
  id        String   @id @default(uuid())
  agendaId  String
  userId    String
  agenda    Agenda   @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([agendaId, userId])
}

enum MetodeKehadiran {
  APLIKASI
  FORM
}

model Kehadiran {
  id          String          @id @default(uuid())
  agendaId    String
  agenda      Agenda          @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  // User aplikasi (opsional)
  userId      String?
  user        User?           @relation(fields: [userId], references: [id])
  // Data manual (untuk non-user)
  namaLengkap String
  nomorHp     String?
  instansi    String?
  jabatan     String?
  metode      MetodeKehadiran @default(APLIKASI)
  waktuHadir  DateTime        @default(now())
  createdAt   DateTime        @default(now())
}

model Disposisi {
  id           String     @id @default(uuid())
  suratMasukId String
  suratMasuk   SuratMasuk @relation(fields: [suratMasukId], references: [id], onDelete: Cascade)
  dibuatOlehId String
  dibuatOleh   User       @relation("DisposisiDibuat", fields: [dibuatOlehId], references: [id])
  penerimaId   String
  penerima     User       @relation("DisposisiPenerima", fields: [penerimaId], references: [id])
  instruksi    String     @db.Text
  catatan      String?    @db.Text
  sudahDibaca  Boolean    @default(false)
  dibacaAt     DateTime?
  jawaban      String?    @db.Text
  dijawabAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
